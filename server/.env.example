# powerkey-issuer 配置示例（部署时复制为 .env 并填值；勿提交真实凭据）

LISTEN_ADDR=:8800

# apiget(new-api) 用户级 API base。
# docker 同网络：http://new-api:3000   公网：https://api.apiget.cc
APIGET_ADMIN_BASE=http://new-api:3000

# 「体验」总账号凭据（系统访问令牌 access_token + user id），用 SOPS 注入，勿明文提交。
# 见 docs/deploy.md「准备体验总账号」。
UMBRELLA_ACCESS_TOKEN=
UMBRELLA_USER_ID=

# 回给客户端写进 settings.json 的中转 base
PUBLIC_BASE_URL=https://api.apiget.cc

# 默认试用模型（服务端改这里即可全网换默认，客户端跟随；如改 Gemini 需对应模型）
TRIAL_MODEL=deepseek-v4-pro

# token 分组（""=随总账号默认；如需指定可填 default / auto）
TRIAL_GROUP=

# 试用额度（USD）
TRIAL_QUOTA_USD=2

# 每 IP 每日发码上限（超限降级到网页自助）
RATE_LIMIT_PER_IP_PER_DAY=20

# 受信代理层数：取 X-Forwarded-For 的「末 N 跳」为真实客户端 IP 做限流。
# 链路 端用户 → BWH Caddy → SG issuer，Caddy 把真实端用户作为 XFF 末跳追加，故 =1。
# XFF[0] 可被客户端伪造，绝不可信；0 = 不信 XFF、只用 RemoteAddr（issuer 直接暴露时用）。
TRUST_XFF_DEPTH=1

# 总账号余额护栏（USD）：铸码前查总账号 GET /api/user/self 的 data.quota，
# 剩余 < 此值则拒铸并降级网页自助（避免铸出死 token 连带拖垮已发放试用）。
# 留空 = 默认 2× TRIAL_QUOTA_USD。余额检查本身出错时 fail-open（仍铸码、打 WARN）。
MIN_UMBRELLA_QUOTA=

# 可选共享密钥（留空=关闭）：设置后 /issue 必须带匹配的 X-Powerkey-Secret 头，
# 用于挡掉绕过 Caddy 的公网直 POST（需 Caddy 注入该头后再开启；默认关闭以不影响现网）。
ISSUE_SHARED_SECRET=

# 异常降级时引导的网页自助领取页
FALLBACK_URL=https://apiget.cc/register?ref=powerkey

# fingerprint->token id 存储路径（挂持久卷；只存 id 不存 key）
STORE_PATH=/data/issued.json
